{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/macayaven/small-cuts/docs/contracts/1.0.0/narrated-scene.schema.json",
  "title": "NarratedScene",
  "description": "One narrated scene, produced by the engine. The SAME object is the viewer's live SSE event (D7) and the library's stored entry (D6); media fields are engine-served URLs.",
  "type": "object",
  "required": [
    "contract_version",
    "scene_id",
    "moment_id",
    "session_id",
    "created_at",
    "style_key",
    "title",
    "narration",
    "visibility",
    "media"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^1\\."
    },
    "scene_id": {
      "type": "string",
      "format": "uuid"
    },
    "moment_id": {
      "type": "string",
      "format": "uuid"
    },
    "session_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "style_key": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "maxLength": 80,
      "description": "derive_title output - the slate/thumbnail text."
    },
    "narration": {
      "type": "string",
      "maxLength": 2000
    },
    "visibility": {
      "enum": [
        "private",
        "shared",
        "public"
      ],
      "default": "private"
    },
    "media": {
      "type": "object",
      "required": [
        "frame_url"
      ],
      "additionalProperties": false,
      "properties": {
        "frame_url": {
          "type": "string",
          "format": "uri-reference"
        },
        "card_url": {
          "type": "string",
          "format": "uri-reference"
        },
        "audio_url": {
          "type": "string",
          "format": "uri-reference"
        },
        "clip_url": {
          "type": "string",
          "format": "uri-reference",
          "description": "Source video segment when the capture app uploaded one (library revisit/share)."
        }
      }
    },
    "engine": {
      "type": "object",
      "description": "Provenance + latency breakdown (the inference team's scoreboard).",
      "additionalProperties": false,
      "properties": {
        "narrator_model": {
          "type": "string"
        },
        "narrator_backend": {
          "enum": [
            "llama_cpp",
            "transformers",
            "mock"
          ]
        },
        "tts_model": {
          "type": "string"
        },
        "latency_ms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "queue": {
              "type": "integer"
            },
            "narration": {
              "type": "integer"
            },
            "tts": {
              "type": "integer"
            },
            "total": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
